                "rgb": [[0,8,[185,228,255,255]],[0.1,4,[185,228,255,255]],[0.9,2,[96,152,255,255]],[1,1,[96,152,255,0]]],
                "sizeX": [[0,1.5],[0.8,1.2],[1,0.4]],
