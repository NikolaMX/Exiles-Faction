            "useRadialVelocityDir": true,
            "velocity": 26,
            "velocityRange": 12,
            "sizeX": 1.2,
            "sizeY": 6,
            "lifetime": 0.3,
            "lifetimeRange": 0.1,
            "emissionBursts": 5,
