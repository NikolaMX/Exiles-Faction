{
    "//": "Stealth Fighter lightning impact. A small icy-blue core flash plus a miniaturised version of the shield_energy_fx tesla arcs: two bursts (second delayed) of ~5 short teslaArc_short arcs each, flying outward in random radial directions.",
    "emitters": [
        {
            "//": "Core impact glow - steady icy-blue hot spot.",
            "spec": {
                "shader": "particle_add_soft",
                "size": [[0,0.5],[0.3,1.2],[1,0.4]],
                "red": 0.6,
                "green": 1.2,
                "blue": 4.0,
                "alpha": [[0,1],[0.7,1],[1,0]],
